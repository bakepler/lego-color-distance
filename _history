=pin2)\n\nwhile True:\n    if uart.any():\n        data = uart.read()\n\n        if data:\n            # Convert first byte to integer distance (simple demo assumption)\n            distance = data[0]\n\n            # Display the distance number\n            display.scroll(distance)\n\n    sleep(100)\n","pxt.json":"{\n    \"name\": \"lego color-distance\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"main.py\"\n    ],\n    \"preferredEditor\": \"tsprj\"\n}\n"}},{"timestamp":1773354628528,"editorVersion":"8.0.18","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables><variable id=\"!/C=e.~5r*^-(x7W`fQ-\">j</variable><variable id=\"j!p],2/9u9lKIZio2F|[\">buf</variable><variable id=\"-a,j(f(A^q5W_G/3^qVM\">list</variable><variable id=\"tOkVQK-8R;#b4njQ3UnH\">buf2</variable><variable id=\"YI6k`P#t?`(]x0fc5m:m\">distance</variable></variables><block type=\"pxt-on-start\" x=\"20\" y=\"20\"><statement name=\"HANDLER\"><block type=\"serial_redirect\"><field name=\"tx\">SerialPin.P1</field><field name=\"rx\">SerialPin.P2</field><field name=\"rate\">BaudRate.BaudRate115200</field><next><block type=\"typescript_statement\"><mutation xmlns=\"http://www.w3.org/1999/xhtml\" line0=\"function lpf2Checksum(buf: Buffer): number {\" line1=\"    let cs = 0xFF\" line2=\"    for (let i = 0; i &lt; buf.length; i++) {\" line3=\"        cs ^= buf.getUint8(i)\" line4=\"    }\" line5=\"    return cs\" line6=\"}\" numlines=\"7\"></mutation><next><block type=\"device_pause\"><comment pinned=\"false\" h=\"80\" w=\"160\">startup</comment><value name=\"pause\"><shadow type=\"timePicker\"><field name=\"ms\">500</field></shadow></value><next><block type=\"function_call\"><mutation name=\"selectDistanceMode\" functionid=\"iWTC_-gMW^.IV:=tHQv@\"></mutation></block></ne